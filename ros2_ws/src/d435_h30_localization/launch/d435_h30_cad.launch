<launch>
  <!-- 参数配置 -->
  <arg name="enable_imu" default="true" />
  <arg name="use_wit_node" default="false" />
  <arg name="imu_port" default="/dev/ttyACM0" />
  <arg name="imu_baud" default="460800" />
  <arg name="cad_map_path" default="/home/picklerick/race_track/cad_map.ply" />
  <arg name="database_path" default="~/race_track/race_track_map.db" />

  <!-- 1. 启动D435相机 -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch" />

  <!-- 2. 启动H30 IMU (可选) -->
  <group if="$(arg enable_imu)">
    <!-- 使用 wit_node (如果可用) -->
    <group if="$(arg use_wit_node)">
      <include file="$(find wit_node)/launch/wit_imu.launch" />
    </group>
    
    <!-- 使用内置的简单 H30 IMU 驱动 -->
    <group unless="$(arg use_wit_node)">
      <node name="h30_imu_driver" pkg="d435_h30_localization" type="h30_imu_driver.py" output="screen">
        <param name="serial_port" value="$(arg imu_port)" />
        <param name="baud_rate" value="$(arg imu_baud)" />
      </node>
    </group>
  </group>

  <!-- 3. 启动RTAB-Map融合定位 (需要先安装 rtabmap_ros) -->
  <node name="rtabmap" pkg="rtabmap_ros" type="rtabmap" output="screen"
    args="--database_path $(arg database_path) --Mem/Mode=2">
    
    <!-- 数据输入 -->
    <remap from="rgb/image" to="/camera/color/image_raw" />
    <remap from="depth/image" to="/camera/aligned_depth_to_color/image_raw" />
    <remap from="rgb/camera_info" to="/camera/color/camera_info" />
    <remap if="$(arg enable_imu)" from="imu" to="/imu/data" />
    
    <!-- CAD模型约束配置 -->
    <param name="Grid/StaticMap" value="true" />
    <param name="Grid/MapPath" value="$(arg cad_map_path)" />
    <param name="Localization/ForceAlign" value="true" />
    <param name="Localization/Enabled" value="true" />
    <param name="Localization/RoiRadius" value="1.0" />
    <param name="Localization/MinInliers" value="15" />
    
    <!-- 融合参数 -->
    <param name="Odom/Strategy" value="1" />
    <param name="Odom/IMUEnabled" value="$(arg enable_imu)" />
  </node>

  <!-- 可视化 -->
  <node name="rviz" pkg="rviz" type="rviz" />
</launch>
