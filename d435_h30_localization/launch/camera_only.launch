<launch>
  <!-- 只使用 D435 相机做定位（不用IMU） -->
  
  使用方法:
    roslaunch d435_h30_localization camera_only.launch [rviz:=true] [rtabmap_viz:=true]
  -->
  
  <!-- 参数配置 -->
  <arg name="rviz" default="true" />
  <arg name="rtabmap_viz" default="true" />
  
  <!-- 位姿传输到STM32参数 -->
  <arg name="send_to_stm32" default="false" />
  <arg name="stm32_port" default="/dev/ttyACM1" />
  <arg name="stm32_baudrate" default="115200" />
  <arg name="stm32_format" default="cm_deg" />
  <arg name="stm32_rate" default="10.0" />
  
  <!-- 1. 启动 D435 相机（启用深度对齐） -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="align_depth" value="true" />
    <arg name="enable_sync" value="true" />
  </include>

  <!-- 添加静态TF变换 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="base_link_to_camera"
    args="0 0 0 0 0 0 base_link camera_link 100" />

  <!-- 2. 启动 RTAB-Map（只用相机，不用IMU） -->
  <include file="$(find rtabmap_launch)/launch/rtabmap.launch">
    <!-- RGB-D 相机配置 -->
    <arg name="rgb_topic" value="/camera/color/image_raw" />
    <arg name="depth_topic" value="/camera/aligned_depth_to_color/image_raw" />
    <arg name="camera_info_topic" value="/camera/color/camera_info" />
    
    <!-- 不使用IMU - 不配置imu_topic参数即可 -->
    
    <!-- 帧配置 -->
    <arg name="frame_id" value="camera_link" />
    <arg name="odom_frame_id" value="odom" />
    <arg name="map_frame_id" value="map" />
    
    <!-- 同步配置 -->
    <arg name="approx_sync" value="true" />
    <arg name="approx_sync_max_interval" value="0.5" />
    
    <!-- 视觉里程计 -->
    <arg name="visual_odometry" value="true" />
    <arg name="odom_topic" value="odom" />
    
    <!-- 启用双可视化 -->
    <arg name="rviz" value="$(arg rviz)" />
    <arg name="rtabmap_viz" value="$(arg rtabmap_viz)" />
    
    <!-- 容错配置 -->
    <arg name="queue_size" value="20" />
    <arg name="args" value="--delete_db_on_start
        --Odom/Strategy 1
        --Odom/IMUEnabled false
        --Odom/ResetOnGap false
        --Odom/ResetOnLowInliers false
        --Odom/FillInfoData true
        --Odom/MinInliers 10
        --Odom/InlierDistance 0.1
        --Odom/RansacIterations 100
        --Mem/IncrementalMemory true
        --Mem/BadSignaturesIgnored true
        --Rtabmap/DetectionRate 1
        --Rtabmap/StartNewMapOnLoopClosure false" />
  </include>

  <!-- 3. 位姿传输到STM32（可选） -->
  <group if="$(arg send_to_stm32)">
    <node pkg="d435_h30_localization" type="rtabmap_odom_handler.py" 
          name="rtabmap_pose_to_stm32" output="screen">
      <param name="port" value="$(arg stm32_port)" />
      <param name="baudrate" value="$(arg stm32_baudrate)" />
      <param name="format" value="$(arg stm32_format)" />
      <param name="send_rate" value="$(arg stm32_rate)" />
    </node>
  </group>
</launch>