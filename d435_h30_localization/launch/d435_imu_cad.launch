<launch>
  <!-- D435 + IMU + CAD 建模融合定位 -->
  
  使用方法:
    roslaunch d435_h30_localization d435_imu_cad.launch [cad_map_path:=/path/to/map.ply] [rviz:=true] [rtabmap_viz:=true]
  -->
  
  <!-- 参数配置 -->
  <arg name="enable_imu" default="true" />
  <arg name="imu_port" default="/dev/ttyACM0" />
  <arg name="imu_baud" default="460800" />
  <arg name="cad_map_path" default="/home/picklerick/race_track/cad_map.ply" />
  <arg name="database_path" default="~/race_track/race_track_map.db" />
  <arg name="rviz" default="false" />
  <arg name="rtabmap_viz" default="true" />
  
  <!-- 位姿传输到STM32参数 -->
  <arg name="send_to_stm32" default="false" />
  <arg name="stm32_port" default="/dev/ttyACM1" />
  <arg name="stm32_baudrate" default="115200" />
  <arg name="stm32_format" default="cm_deg" />
  <arg name="stm32_rate" default="10.0" />
  
  <!-- 串口助手参数 -->
  <arg name="serial_assistant" default="true" />
  
  <!-- 1. 启动 D435 相机（启用深度对齐） -->
  <include file="$(find realsense2_camera)/launch/rs_camera.launch">
    <arg name="align_depth" value="true" />
    <arg name="enable_sync" value="true" />
  </include>

  <!-- 2. 启动 YESENSE 官方 IMU 驱动 -->
  <group if="$(arg enable_imu)">
    <node pkg="yesense_imu" type="yesense_imu_node" name="yesense_imu_node" required="true" output="screen">
      <param name="port" value="$(arg imu_port)" />
      <param name="baud_rate" value="$(arg imu_baud)" />
    </node>
  </group>

  <!-- 添加静态TF变换 - 解决unknown frame问题 -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="base_link_to_camera"
    args="0 0 0 0 0 0 base_link camera_link 100" />
  
  <node pkg="tf2_ros" type="static_transform_publisher" name="camera_to_imu"
    args="0 0 0 0 0 0 camera_link imu_link 100" />

  <!-- 3. 启动RTAB-Map融合定位 (使用CAD模型约束) -->
  <node name="rtabmap" pkg="rtabmap_ros" type="rtabmap" output="screen"
    args="--database_path $(arg database_path) --Mem/Mode=2
          --Odom/Strategy 1
          --Odom/IMUEnabled true
          --Odom/IMUWeight 0.7
          --Optimizer/GravitySigma 0.01
          --Odom/ResetOnGap false
          --Odom/ResetOnLowInliers false
          --Odom/FillInfoData true
          --Odom/MinInliers 10
          --Odom/InlierDistance 0.1
          --Odom/RansacIterations 100
          --Odom/IMUBufferSize 2000
          --Odom/IMUMaxSpinUpWait 2.0
          --Odom/IMUAngleThreshold 5.0
          --Odom/IMUGravityVelocityThreshold 5.0
          --Mem/IncrementalMemory true
          --Mem/BadSignaturesIgnored true
          --Rtabmap/DetectionRate 1
          --Rtabmap/StartNewMapOnLoopClosure false">
    
    <!-- 数据输入 -->
    <remap from="rgb/image" to="/camera/color/image_raw" />
    <remap from="depth/image" to="/camera/aligned_depth_to_color/image_raw" />
    <remap from="rgb/camera_info" to="/camera/color/camera_info" />
    <remap if="$(arg enable_imu)" from="imu" to="/imu/data" />
    
    <!-- CAD模型约束配置 -->
    <param name="Grid/StaticMap" value="true" />
    <param name="Grid/MapPath" value="$(arg cad_map_path)" />
    <param name="Localization/ForceAlign" value="true" />
    <param name="Localization/Enabled" value="true" />
    <param name="Localization/RoiRadius" value="1.0" />
    <param name="Localization/MinInliers" value="15" />
    
    <!-- 融合参数 -->
    <param name="Odom/Strategy" value="1" />
    <param name="Odom/IMUEnabled" value="$(arg enable_imu)" />
  </node>

  <!-- 4. 启动 RTAB-Map Viz 可视化（可选） -->
  <node name="rtabmap_viz" pkg="rtabmap_ros" type="rtabmap_viz" output="screen" if="$(arg rtabmap_viz)">
    <remap from="rgb/image" to="/camera/color/image_raw" />
    <remap from="depth/image" to="/camera/aligned_depth_to_color/image_raw" />
    <remap from="rgb/camera_info" to="/camera/color/camera_info" />
  </node>

  <!-- 启动 RViz 可视化（可选） -->
  <node name="rviz" pkg="rviz" type="rviz" if="$(arg rviz)" />

  <!-- 5. 位姿传输到STM32（可选） -->
  <group if="$(arg send_to_stm32)">
    <node pkg="d435_h30_localization" type="rtabmap_odom_handler.py" 
          name="rtabmap_pose_to_stm32" output="screen">
      <param name="port" value="$(arg stm32_port)" />
      <param name="baudrate" value="$(arg stm32_baudrate)" />
      <param name="format" value="$(arg stm32_format)" />
      <param name="send_rate" value="$(arg stm32_rate)" />
    </node>
  </group>
  
  <!-- 串口助手（可选） -->
  <group if="$(arg serial_assistant)">
    <node pkg="d435_h30_localization" type="serial_assistant.py" 
          name="serial_assistant" output="screen" 
          launch-prefix="gnome-terminal --title='串口助手' --geometry=80x20+100+100 -- " />
  </group>
</launch>